<div style="height: 150px" id="multi-metal-voltmeter-container"></div>

<script type="module">
    import ElectrochemicalSpeciesBandDiagram from '{{ esbdJsPath }}ElectrochemicalSpeciesBandDiagram.js';
    import { SPECIES, REGION } from '{{ esbdJsPath }}figureDefs.js';

    const diagram = new ElectrochemicalSpeciesBandDiagram(
        'multi-metal-voltmeter-container',
        { electron: SPECIES.electron }
    );

    const boundaries = [0.0, 0.18, 0.36, 0.54, 0.72, 1.0];
    const x_deltaV = 0.86;
    diagram.setSpatialLayout(boundaries, [
        { name: 'Device', color: '#E0E0A0' },
        { name: 'Nickel', color: '#b0b0b0' },
        { name: 'Copper', color: '#F0B090' },
        { ...REGION.metal, name: 'Solder' },
        { name: 'Voltmeter', color: '#f8f8f8' },
    ]);

    const V_el = +0.45;
    diagram.setVRange(-0.15, V_el + 0.15);

    diagram.updateTraceData([
        {
            id: `electron_trace`,
            speciesId: 'electron',
            curveType: 'voltage',
            showLabel: true,
            x: [0, x_deltaV],
            y: [V_el, V_el],
        },
        {
            id: `electron_trace_gnd`,
            speciesId: 'electron',
            curveType: 'voltage',
            showLabel: true,
            label: '\\mathrm{GND}',
            x: [x_deltaV, 1],
            y: [0, 0],
        },
    ]);

    diagram.updateVerticalMarkers([
        {
            id: 'voltmeter',
            symbol: 'V',
            x: x_deltaV,
            yDefs: [{ y: 0 }, { y: V_el }],
            popupCallback: () => 'Voltmeter',
        },
    ]);
</script>
