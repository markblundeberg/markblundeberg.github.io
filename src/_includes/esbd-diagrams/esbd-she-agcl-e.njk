{% set idprefix = "esbd-she-agcl-e" %} {# standard hydrogen electrode with agcl electrode #}
{% import "macros/controls.njk" as controls %}
<div class="bd-container" id="{{idprefix}}-container"></div>
{{ controls.slider(idprefix + "-hcl-slider", "$\\mathrm{HCl}$ concentration", { min: -3.1, max: 1.1, step: "any", value: -1.7, readout: true, unit: "mol/kg", snap: 0 }) }}
{{ controls.slider(idprefix + "-h2-slider", "$\\mathrm{H}_2$ pressure", { min: -2, max: 2, step: "any", value: -0.8, readout: true, unit: "bar", snap: 0 }) }}
<div
    class="bd-readout"
    style="text-align: center; font-size: 0.85em; color: #444; margin-top: 0.3em"
>
    Cell voltage $\Delta V_{\mathrm{e}^-}$: <span id="{{idprefix}}-voltage"></span> V
</div>

<script type="module">
    import ElectrochemicalSpeciesBandDiagram from '{{ esbdJsPath }}ElectrochemicalSpeciesBandDiagram.js';
    import { SPECIES, REGION } from '{{ esbdJsPath }}figureDefs.js';
    import { makeSlider } from '{{ esbdJsPath }}utils.js';

    const hSlider = document.getElementById('{{ idprefix }}-hcl-slider');
    const hConcSpan = document.getElementById('{{ idprefix }}-hcl-slider-readout');
    const h2Slider = document.getElementById('{{ idprefix }}-h2-slider');
    const h2PressSpan = document.getElementById('{{ idprefix }}-h2-slider-readout');
    const voltsSpan = document.getElementById('{{ idprefix }}-voltage');

    const diagram = new ElectrochemicalSpeciesBandDiagram('{{idprefix}}-container', {
        hplus: SPECIES.proton,
        clminus: SPECIES.chloride,
        electron: SPECIES.electron,
    });

    const boundaries = [0.0, 0.25, 0.65, 0.75, 1.0];
    diagram.setSpatialLayout(boundaries, [
        { ...REGION.metal, name: 'Pt' },
        REGION.solution,
        { name: 'AgCl', color: '#ffe' },
        { ...REGION.metal, name: 'Ag' },
    ]);

    const R = 8.31446261815324; // Gas constant (J/mol·K)
    const F = 96485.3321233100184; // Faraday constant (C/mol)
    const T = 298.15; // Temperature (K, 25°C)
    const RT = R * T;
    const RT_F = RT / F;
    const dV_HCl_std = (0 + -131.23e3) / F; // V^0_H+ - V^0_Cl-
    const mu_AgCl = -109.8e3; // chem potential of AgCl
    const mu_Ag = 0; // chem potential of Ag
    const mu_H2_1bar = 0; // chemical potential of H2 at 1 bar fugacity

    const E0_SSCE_SHE =
        mu_H2_1bar / (2 * F) - dV_HCl_std - (mu_Ag - mu_AgCl) / F;

    diagram.setVRange(-0.35, 0.55);

    function updateDiagrams() {
        const a_hcl = Math.pow(10, parseFloat(hSlider.value));
        const a_h2 = Math.pow(10, parseFloat(h2Slider.value));

        hConcSpan.textContent = a_hcl.toExponential(2);
        h2PressSpan.textContent = a_h2.toPrecision(3);

        const a_hplus = a_hcl;
        const a_clminus = a_hcl;

        const V0_SHE = 0;
        const V_el = V0_SHE + RT_F * Math.log(a_hplus / Math.sqrt(a_h2));
        const V0_SSCE = V0_SHE + E0_SSCE_SHE;
        const V_el_Ag = V0_SSCE - RT_F * Math.log(a_clminus);

        const V_cell = V_el_Ag - V_el;
        voltsSpan.textContent = V_cell.toPrecision(3);

        const b = boundaries;
        diagram.updateTraceData([
            {
                id: `electron_trace`,
                speciesId: 'electron',
                curveType: 'voltage',
                showLabel: true,
                x: [b[0], b[1]],
                y: [V_el, V_el],
            },
            {
                id: `electron_she`,
                speciesId: 'electron',
                curveType: 'standardStateImplied',
                label: String.raw`V^\circ_{\mathrm{e}^-}(\mathrm{SHE})`,
                showLabel: true,
                x: [b[1], b[3]],
                y: [V0_SHE, V0_SHE],
            },
            {
                id: `electron_ssce`,
                speciesId: 'electron',
                curveType: 'standardStateImplied',
                label: String.raw`V^\circ_{\mathrm{e}^-}(\mathrm{SSCE})`,
                showLabel: true,
                x: [b[1], b[3]],
                y: [V0_SSCE, V0_SSCE],
            },
            {
                id: `electron_trace2`,
                speciesId: 'electron',
                curveType: 'voltage',
                showLabel: true,
                x: [b[3], b[4]],
                y: [V_el_Ag, V_el_Ag],
            },
        ]);

        diagram.updateVerticalMarkers([
            {
                id: 'she',
                symbol: 'a',
                x: b[1],
                yDefs: [{ y: V_el }, { y: V0_SHE }],
                popupCallback: () =>
                    String.raw`$\mathrm{H}^+ + \mathrm{e}^- \rightleftharpoons \tfrac{1}{2}\mathrm{H}_2$`,
            },
            {
                id: 'agcl',
                symbol: 'a',
                x: b[3],
                yDefs: [{ y: V_el_Ag }, { y: V0_SSCE }],
                popupCallback: () =>
                    String.raw`$\mathrm{AgCl} + \mathrm{e}^- \rightleftharpoons \mathrm{Ag} + \mathrm{Cl}^-$`,
            },
        ]);
    }

    makeSlider('{{idprefix}}-hcl-slider', () => updateDiagrams(), { fire: false });
    makeSlider('{{idprefix}}-h2-slider', () => updateDiagrams(), { fire: false });
    updateDiagrams();
</script>
