{% set idprefix = "esbd-lib-eq" %}
{% import "macros/controls.njk" as controls %}
    <div class="bd-container" id="{{idprefix}}-container"></div>
    {{ controls.slider(idprefix + "-soc", "State of charge", { min: 0, max: 100, step: 1, value: 50, readout: true, unit: "%" }) }}
    <div
        class="bd-readout"
        style="text-align: center; font-size: 0.85em; color: #444; margin-top: 0.3em"
    >
        Cell voltage (OCV): <span id="{{idprefix}}-ocv"></span> V
    </div>

<script type="module">
    import ElectrochemicalSpeciesBandDiagram from '{{ esbdJsPath }}ElectrochemicalSpeciesBandDiagram.js';
    import { SPECIES, REGION } from '{{ esbdJsPath }}figureDefs.js';
    import { makeSlider } from '{{ esbdJsPath }}utils.js';

    const socReadout = document.getElementById('{{idprefix}}-soc-readout');
    const ocvOut = document.getElementById('{{idprefix}}-ocv');

    // Open-circuit-voltage curves vs Li/Li+, from Chen et al. (2020),
    // J. Electrochem. Soc. 167: 080534.
    const anodeOCV = (x) =>
        1.9793 * Math.exp(-39.3631 * x) +
        0.2482 -
        0.0909 * Math.tanh(29.8538 * (x - 0.1234)) -
        0.04478 * Math.tanh(14.9159 * (x - 0.2769)) -
        0.0205 * Math.tanh(30.4444 * (x - 0.6103));
    const cathodeOCV = (y) => {
        const sto = 0.25 + y * 0.75;
        return (
            -0.809 * sto +
            4.4875 -
            0.0428 * Math.tanh(18.5138 * (sto - 0.5542)) -
            17.7326 * Math.tanh(15.789 * (sto - 0.3117)) +
            17.5842 * Math.tanh(15.9308 * (sto - 0.312))
        );
    };

    const diagram = new ElectrochemicalSpeciesBandDiagram('{{idprefix}}-container', {
        li_ion: SPECIES.lithium,
        electron: SPECIES.electron,
    });

    // 7 regions: collector | anode | electrolyte | separator | electrolyte | cathode | collector
    const boundaries = [0, 0.1, 0.35, 0.48, 0.52, 0.65, 0.9, 1.0];
    diagram.setSpatialLayout(boundaries, [
        { name: 'Collector', color: '#AAAAAA' },
        { name: 'Anode (graphite)', color: '#DDDDDD' },
        { ...REGION.solution, name: 'Electrolyte' },
        { name: 'Separator', color: '#FFFFE0' },
        { ...REGION.solution, name: 'Electrolyte' },
        { name: 'Cathode (oxide)', color: '#FFDDDD' },
        { name: 'Collector', color: '#AAAAAA' },
    ]);
    diagram.setVRange(-1.2, 4.7);

    const b = boundaries;
    function doUpdate(soc) {
        const x_anode = (soc + 5) / 105.0; // anode lithiation
        const y_cathode = 1.0 - x_anode; // cathode lithiation
        const ocvA = anodeOCV(x_anode);
        const ocvC = cathodeOCV(y_cathode);
        const cellV = ocvC - ocvA;

        const V_e_anode = 0;
        const V_Li = -ocvA;
        const V_e_cathode = cellV;

        socReadout.textContent = soc.toFixed(0);
        ocvOut.textContent = cellV.toFixed(3);

        diagram.updateTraceData([
            {
                id: 'e_anode',
                speciesId: 'electron',
                curveType: 'voltage',
                showLabel: true,
                x: [b[0], b[2]],
                y: [V_e_anode, V_e_anode],
            },
            {
                id: 'e_cathode',
                speciesId: 'electron',
                curveType: 'voltage',
                showLabel: true,
                x: [b[5], b[7]],
                y: [V_e_cathode, V_e_cathode],
            },
            {
                id: 'li_elyte',
                speciesId: 'li_ion',
                curveType: 'voltage',
                showLabel: true,
                x: [b[1], b[6]],
                y: [V_Li, V_Li],
            },
        ]);

        diagram.updateVerticalMarkers([
            {
                id: 'anode_eq',
                symbol: '⇌',
                x: 0.5 * (b[1] + b[2]),
                yDefs: [{ y: V_e_anode }, { y: V_Li }],
                popupCallback: () =>
                    '$\\mathrm{Li(graphite)} \\rightleftharpoons \\mathrm{Li}^+ + \\mathrm{e}^-$',
            },
            {
                id: 'cathode_eq',
                symbol: '⇌',
                x: 0.5 * (b[5] + b[6]),
                yDefs: [{ y: V_e_cathode }, { y: V_Li }],
                popupCallback: () =>
                    '$\\mathrm{Li(oxide)} \\rightleftharpoons \\mathrm{Li}^+ + \\mathrm{e}^-$',
            },
        ]);
    }

    makeSlider('{{idprefix}}-soc', (v) => doUpdate(v));
</script>
