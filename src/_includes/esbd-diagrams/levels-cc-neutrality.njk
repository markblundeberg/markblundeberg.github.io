{% set idprefix = "levels-cc-neutrality" %}
{% import "macros/controls.njk" as controls %}
<div class="bd-container" id="{{idprefix}}-levels" style="height: 205px; max-width: 250px"></div>
<div class="bd-container" id="{{idprefix}}-charge" style="height: 165px; max-width: 250px"></div>
{{ controls.slider(idprefix + "-ladder-slider", "Ladder offset", { min: -0.07, max: 0.07, step: "any", value: 0, snap: -0.041 }) }}

<script type="module">
    import EnergyLevelsDiagram from '{{ esbdJsPath }}EnergyLevelsDiagram.js';
    import XYPlot from '{{ esbdJsPath }}XYPlot.js';
    import { SPECIES } from '{{ esbdJsPath }}figureDefs.js';
    import { makeSlider, linspace } from '{{ esbdJsPath }}utils.js';

    // Toy multi-ion solution: X+ (z=1), Y2+ (z=2), Z- (z=-1), all V_i pinned,
    // plus a fixed background charge; the rigid ladder slides by s.
    // Concentrations follow the ideal-dilute law (gaps in real volts), so net
    // charge rho(s) is monotone with ONE zero crossing (s* = -0.041 V, marked
    // on the slider's datalist).
    const DEC = 0.05916;
    const xOff = +0.12;
    const yOff = -0.06;
    const zOff = 0;
    const IONS = [
        { key: 'x', z: 1,  V: xOff - 0.5*DEC, V0off: xOff, sp: SPECIES.sodium, sym: 'X^{+}' },
        { key: 'y', z: 2,  V: yOff - 1*DEC, V0off: yOff, sp: SPECIES.zinc, sym: 'Y^{2+}' },
        { key: 'z', z: -1, V: zOff + 0.8*DEC, V0off: zOff, sp: SPECIES.chloride, sym: 'Z^{-}' },
    ];
    const rho_bg = -2;
    const conc = (ion, s) =>
        Math.pow(10, (ion.z * (ion.V - (s + ion.V0off))) / DEC);
    const rho = (s) => IONS.reduce((acc, ion) => acc + ion.z * conc(ion, s), rho_bg);

    const levels = new EnergyLevelsDiagram('{{idprefix}}-levels', {
        yAxisLabel: 'Voltage (V)',
        yRange: [-0.17, 0.21],
        categories: [{ id: 'soln', label: 'Solution' }],
        bandMinPaddingOuter: { left: 48, right: 40 },
    });

    // Lower panel: net charge vs ladder offset (a non-spatial x axis → XYPlot).
    const S_MIN = -0.07,
        S_MAX = 0.07;
    const chart = new XYPlot('{{idprefix}}-charge', {
        xLabel: 'ladder offset',
        yLabel: 'Net charge',
        xRange: [S_MIN, S_MAX],
        yRange: [-5, 8],
        xMode: 'abstract',
        yMode: 'abstract',
        margins: { bottom: 30, left: 35, right:20 },
    });
    const sGrid = linspace(S_MIN, S_MAX, 121);
    // Faint component traces (per-ion exponentials in the ions' colors, flat
    // background) under the bold total, so the sum is visibly a sum.
    const FAINT = { lineWidth: 1.25, opacity: 0.55 };
    chart.updateTraceData([
        {
            id: 'zero',
            label: '0',
            color: '#999',
            style: { lineWidth: 1, dasharray: '4,3' },
            x: [S_MIN, S_MAX],
            y: [0, 0],
        },
        ...IONS.map((ion) => ({
            id: 'q_' + ion.key,
            showLabel: false,
            color: ion.sp.color,
            style: FAINT,
            x: sGrid,
            y: sGrid.map((s) => ion.z * conc(ion, s)),
        })),
        {
            id: 'q_bg',
            label: '\\scriptstyle \\rho_{\\mathrm{bg}}',
            labelFrac: 0.75,
            color: '#777',
            style: FAINT,
            x: [S_MIN, S_MAX],
            y: [rho_bg, rho_bg],
        },
        {
            id: 'rho',
            label: '\\textstyle \\rho_{\\mathrm{bg}} + \\sum_i q_i c_i',
            labelFrac: 0.1,
            labelHAlign: 'left',
            color: '#444',
            style: { lineWidth: 2 },
            x: sGrid,
            y: sGrid.map((s) => (rho(s))),
        },
    ]);

    function update(s) {
        const levelData = [];
        for (const ion of IONS) {
            levelData.push({
                categoryId: 'soln',
                levelId: 'v_' + ion.key,
                yValue: ion.V,
                label: `V_{${ion.sym}}`,
                color: ion.sp.color,
                style: { lineWidth: 3 },
            });
            levelData.push({
                categoryId: 'soln',
                levelId: 'v0_' + ion.key,
                yValue: s + ion.V0off,
                label: `V^\\circ_{${ion.sym}}`,
                color: ion.sp.color,
                style: { lineWidth: 1 },
                labelSide: 'left',
            });
        }
        levels.setLevels(levelData);

        chart.updateMarkers([{ id: 'here', x: s, y: (rho(s)) }]);
    }

    makeSlider('{{idprefix}}-ladder-slider', update);
</script>
