{% set idprefix = "esbd-offsets-galore" %}
{% import "macros/controls.njk" as controls %}
<figure class="demo-container" style="max-width: 470px">
    <div class="bd-container" id="{{idprefix}}-plot" style="height: 320px; width: 100%"></div>
    <div id="{{idprefix}}-sliders" style="display: grid; grid-template-columns: max-content minmax(0, 200px); gap: 0.35em 0.7em; align-items: center; justify-content: center; margin-top: 0.7em">
        {{ controls.slider(idprefix + "-float", "Global float", { min: -0.4, max: 0.4, step: "any", value: 0, snap: 0, inline: true }) }}
        {{ controls.slider(idprefix + "-muH", "Ref: H", { min: -0.4, max: 0.4, step: "any", value: 0, snap: 0, inline: true }) }}
        {{ controls.slider(idprefix + "-muO", "Ref: O", { min: -0.4, max: 0.4, step: "any", value: 0, snap: 0, inline: true }) }}
        {{ controls.slider(idprefix + "-muLi", "Ref: Li", { min: -0.4, max: 0.4, step: "any", value: 0, snap: 0, inline: true }) }}
        {{ controls.slider(idprefix + "-act1", "Soln 1: act.", { min: -0.3, max: 0.3, step: "any", value: 0, snap: 0, inline: true }) }}
        {{ controls.slider(idprefix + "-phi1", "Soln 1: φ", { min: -0.3, max: 0.3, step: "any", value: 0, snap: 0, inline: true }) }}
        {{ controls.slider(idprefix + "-act2", "Soln 2: act.", { min: -0.3, max: 0.3, step: "any", value: 0, snap: 0, inline: true }) }}
        {{ controls.slider(idprefix + "-phi2", "Soln 2: φ", { min: -0.3, max: 0.3, step: "any", value: 0, snap: 0, inline: true }) }}
    </div>
</figure>

<script type="module">
    import ElectrochemicalSpeciesBandDiagram from '{{ esbdJsPath }}ElectrochemicalSpeciesBandDiagram.js';
    import { SPECIES, REGION } from '{{ esbdJsPath }}figureDefs.js';
    import { makeSlider } from '{{ esbdJsPath }}utils.js';

    // Two solutions side by side. Every line is computed from the base state plus
    // whatever the convention/gauge sliders do to it. (F = 1, arbitrary units.)
    const boundaries = [0.0, 0.4, 0.6, 1.0];
    const regions = [
        { ...REGION.solution, name: 'Aqueous acid' },
        { ...REGION.metal, name:"Metals" },
        { ...REGION.solution2, name: 'Li⁺ electrolyte' },
    ];

    // kind: Vi = species voltage rail | V0 = standard-state line | phi = inner potential
    //       | Ve = electron level (electrode / redox half-reaction)
    // nH/nO/nLi = atom counts of the slider elements; region = 1 or 2.
    const x_soln_1 = [boundaries[0],boundaries[1]];
    const x_metal = [boundaries[1],boundaries[2]];
    const x_soln_2 = [boundaries[2],boundaries[3]];
    const base = [
        // Solution 1 — aqueous acid
        { id: 'h_v',   species: 'proton',    curveType: 'voltage',       kind: 'Vi',  region: 1, nH: 1,        v:  0.40, x: x_soln_1 },
        { id: 'h_v0',  species: 'proton',    curveType: 'standardState', kind: 'V0',  region: 1, nH: 1,        v:  0.68, x: x_soln_1 },
        { id: 'oh_v',  species: 'hydroxide', curveType: 'voltage',       kind: 'Vi',  region: 1, nH: 1, nO: 1, v: -0.45, x: x_soln_1 },
        { id: 'oh_v0', species: 'hydroxide', curveType: 'standardState', kind: 'V0',  region: 1, nH: 1, nO: 1, v: -1.05, x: x_soln_1 },
        { id: 'phi1',                        curveType: 'phi',           kind: 'phi', region: 1,               v:  0.08, x: x_soln_1 },
        // Metal
        { id: 'e1',    species: 'electron',  curveType: 'voltage',       kind: 'Ve',  region: 2,               v:  0.20, x: x_metal },
        // Solution 2 — Li⁺ electrolyte
        { id: 'li_v',  species: 'lithium',   curveType: 'voltage',       kind: 'Vi',  region: 3, nLi: 1,       v:  0.15, x: x_soln_2 },
        { id: 'li_v0', species: 'lithium',   curveType: 'standardState', kind: 'V0',  region: 3, nLi: 1,       v:  0.45, x: x_soln_2 },
        { id: 'x_v',   species: 'chloride',  curveType: 'voltage',       kind: 'Vi',  region: 3,               v: -0.65, x: x_soln_2 },
        { id: 'phi2',                        curveType: 'phi',           kind: 'phi', region: 3,               v: -0.08, x: x_soln_2 },
    ];

    const esbd = new ElectrochemicalSpeciesBandDiagram('{{idprefix}}-plot', {
        proton: SPECIES.proton,
        hydroxide: SPECIES.hydroxide,
        lithium: SPECIES.lithium,
        chloride: SPECIES.chloride,
        electron: SPECIES.electron,
    }, { yMode: 'abstract' });
    esbd.setSpatialLayout(boundaries, regions);
    esbd.setVRange(-1.7, 1.7);

    const val = (name) => parseFloat(document.getElementById('{{idprefix}}-' + name).value);

    function update() {
        const f = val('float');
        const mu = { H: val('muH'), O: val('muO'), Li: val('muLi') };
        const A = { 1: val('act1'), 2:0, 3: val('act2') };
        const P = { 1: val('phi1'), 2:0, 3: val('phi2') };

        const traces = base.map((t) => {
            let y = t.v + f; // the global float moves everything

            if (t.kind === 'Vi' || t.kind === 'V0') {
                // element references move μ̄_i (and V°) by atom-count / charge
                const z = SPECIES[t.species].z;
                y += ((t.nH || 0) * mu.H + (t.nO || 0) * mu.O + (t.nLi || 0) * mu.Li) / z;
            }
            if (t.kind === 'V0') y += A[t.region]; // activity convention reallocates V° ↔ activity
            if (t.kind === 'phi') y += A[t.region] + P[t.region]; // φ rides activity, plus its own choice
            // kind 'Ve': float only — electrons carry no element, redox levels conserve them

            return {
                id: t.id,
                speciesId: t.species ?? null,
                curveType: t.curveType,
                showLabel: true,
                label: t.label ?? null,
                x: t.x,
                y: [y, y],
            };
        });
        esbd.updateTraceData(traces);
    }

    ['float', 'muH', 'muO', 'muLi', 'act1', 'phi1', 'act2', 'phi2'].forEach((n) =>
        makeSlider('{{idprefix}}-' + n, () => update(), { fire: false })
    );
    update();
</script>
