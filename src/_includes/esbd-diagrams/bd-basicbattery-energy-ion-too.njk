{% set idprefix = ["bd-basicbattery-energy-ion-too-", idsuffix] | join %}
{% import "macros/controls.njk" as controls %}
    <div class="bd-container" id="{{ idprefix }}"></div>
    {{ controls.slider(idprefix + "-current-slider", "Current", { min: -1, max: 1, step: "any", value: 0, readout: true, readoutInit: "equilibrium", snap: 0 }) }}
    {{ controls.slider(idprefix + "-dphi-slider", "Electrostatic offset $\\Delta\\phi$", { min: -0.5, max: 0.5, step: "any", value: 0 }) }}

<script type="module">
    import BandDiagram from '{{ esbdJsPath }}BandDiagram.js';
    import { SPECIES, REGION } from '{{ esbdJsPath }}figureDefs.js';
    import { makeSlider } from '{{ esbdJsPath }}utils.js';

    const dPhiSlider = document.getElementById('{{ idprefix }}-dphi-slider');
    const currentSlider = document.getElementById('{{ idprefix }}-current-slider');
    const currentText = document.getElementById('{{ idprefix }}-current-slider-readout');

    const diagram = new BandDiagram('{{ idprefix }}');

    const boundaries = [0.0, 0.15, 0.3, 0.7, 0.85, 1.0];
    diagram.setSpatialLayout(
        boundaries,
        [
            { name: 'Anode', color: '#AAAAAA' },
            { name: 'Anode-active', color: '#bbb' },
            { ...REGION.solution, name: 'Electrolyte' },
            { name: 'Cathode-active', color: '#bbb' },
            { name: 'Cathode', color: '#AAAAAA' },
        ],
        [
            { label: 'Anode', x: 0.15 },
            { label: 'Electrolyte', x: 0.5 },
            { label: 'Cathode', x: 0.85 },
        ]
    );

    diagram.setYLabel('Electron/ion energy (eV)');
    diagram.setYRange(-4.1, +0.8);

    const R_anode = 0.03;
    const R_cathode = R_anode;
    const R_Li = 0.2;
    const OCV_anode = 0.1;
    const OCV_cathode = 3.4;

    const li_color = SPECIES.lithium.color;
    const electron_color = SPECIES.electron.color;

    function updateDiagrams() {
        const dphi = parseFloat(dPhiSlider.value);
        const current = parseFloat(currentSlider.value);

        currentText.textContent =
            current > 0 ? 'discharging⇨' : current < 0 ? '⇦charging' : 'equilibrium';

        const V_left = 0.0 + dphi;
        const V_Li_left = V_left - OCV_anode;
        const V_Li_right = V_Li_left - current * R_Li;
        const V_right = V_Li_right + OCV_cathode;
        const V_anode = V_left - current * R_anode;
        const V_cathode = V_right + current * R_cathode;

        const b = boundaries;
        diagram.updateTraceData([
            {
                id: 'anode_trace',
                label: '\\bar\\mu_{\\mathrm{e}^-}',
                showLabel: true,
                color: electron_color,
                x: [b[0], b[1], b[2]],
                y: [-V_left, -V_left, -V_anode],
            },
            {
                id: 'li_trace',
                label: '\\bar\\mu_{\\mathrm{Li}^+}',
                showLabel: true,
                color: li_color,
                x: [b[1], b[4]],
                y: [+V_Li_left, +V_Li_right],
            },
            {
                id: 'cathode_trace',
                label: '\\bar\\mu_{\\mathrm{e}^-}',
                showLabel: true,
                color: electron_color,
                x: [b[3], b[4], b[5]],
                y: [-V_cathode, -V_right, -V_right],
            },
        ]);
    }

    makeSlider('{{ idprefix }}-current-slider', () => updateDiagrams(), { fire: false });
    makeSlider('{{ idprefix }}-dphi-slider', () => updateDiagrams(), { fire: false });
    updateDiagrams();
</script>
