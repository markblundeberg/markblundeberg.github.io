{% set idprefix = "esbd-cc-ities" %}
<div class="bd-container" id="{{idprefix}}-container" style="height: 270px"></div>

<script type="module">
    import ElectrochemicalSpeciesBandDiagram from '{{ esbdJsPath }}ElectrochemicalSpeciesBandDiagram.js';
    import { SPECIES, REGION } from '{{ esbdJsPath }}figureDefs.js';
    import { linspace } from '{{ esbdJsPath }}utils.js';

    // Schematic ITIES with a generic 1:1 salt C+ A- partitioning between water
    // and an immiscible organic solvent. Chemistry deliberately left generic
    // (no specific system settled on yet); to make it concrete, set the two
    // water-side gaps and the organic-side gaps from a real salt's transfer
    // energies. For any single 1:1 salt, the electroneutral distribution
    // potential makes the two rungs deform EQUALLY AND OPPOSITELY by
    // (RT/2F)ln(K_C/K_A); here the salt prefers water, so both organic-side
    // gaps widen: the ladder stretches rather than stepping rigidly.
    const GAP_W = 0.13; // |V_i - V°_i| in water (both ions; c_w equal by neutrality)
    const GAP_O = 0.3; // |gap| in the organic phase (same for both ions)
    const V_C = 0.4,
        V_A = -0.4; // the shared ions' flat voltages (gauge arbitrary)

    const diagram = new ElectrochemicalSpeciesBandDiagram(
        '{{idprefix}}-container',
        {
            cation: { z: 1, color: SPECIES.potassium.color, mathLabel: '\\mathrm{C}^{+}' },
            anion: { z: -1, color: SPECIES.nitrate.color, mathLabel: '\\mathrm{A}^{-}' },
        },
        { yMode: 'abstract', margins: { right: 62, left: 28 } }
    );
    diagram.setSpatialLayout([0, 0.5, 1], [
        { ...REGION.solution, name: 'Water' },
        { ...REGION.solution2, name: 'Organic' },
    ]);
    diagram.setVRange(-0.9, 0.9);

    const x = linspace(0, 1, 101);
    const s = x.map((xi) => {
        const t = Math.min(1, Math.max(0, (xi - 0.465) / 0.07));
        return t * t * (3 - 2 * t);
    });

    diagram.updateTraceData([
        {
            id: 'v0c',
            speciesId: 'cation',
            curveType: 'standardState',
            labelFrac: 0.1,
            x: x,
            y: s.map((t) => V_C + GAP_W + t * (GAP_O - GAP_W)),
        },
        {
            id: 'vc',
            speciesId: 'cation',
            curveType: 'voltage',
            x: [0, 1],
            y: [V_C, V_C],
        },
        {
            id: 'va',
            speciesId: 'anion',
            curveType: 'voltage',
            x: [0, 1],
            y: [V_A, V_A],
        },
        {
            id: 'v0a',
            speciesId: 'anion',
            curveType: 'standardState',
            labelFrac: 0.1,
            x: x,
            y: s.map((t) => V_A - GAP_W - t * (GAP_O - GAP_W)),
        },
    ]);
</script>
