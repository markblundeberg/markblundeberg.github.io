{% set idprefix = ["esbd-nacl-dilute", idsuffix] | join %}
{% import "macros/controls.njk" as controls %}
<figure class="demo-container" style="max-width: 300px">
    <div
        id="{{idprefix}}-bd-container"
        class="bd-container"
        style="height: 300px; width: 100%"
    ></div>

    {{ controls.slider(idprefix + "-concSlider", "Added NaCl", { min: -8, max: 1, step: 0.1, value: -6, readout: true, unit: "mol/L" }) }}
    {{ controls.slider(idprefix + "-phiSlider", "Float", { min: -1, max: 1, step: "any", value: 0 }) }}
</figure>

<script type="module">
    import ElectrochemicalSpeciesBandDiagram from '{{ esbdJsPath }}ElectrochemicalSpeciesBandDiagram.js';
    import { SPECIES, REGION } from '{{ esbdJsPath }}figureDefs.js';
    import { makeSlider } from '{{ esbdJsPath }}utils.js';

    const concSlider = document.getElementById('{{idprefix}}-concSlider');
    const concValueSpan = document.getElementById('{{idprefix}}-concSlider-readout');
    const phiSlider = document.getElementById('{{idprefix}}-phiSlider');
    const plotContainerId = '{{idprefix}}-bd-container';

    // --- Constants ---
    const R = 8.31446261815324; // Gas constant (J/mol·K)
    const F = 96485.3321233100184; // Faraday constant (C/mol)
    const T = 298.15; // Temperature (K, 25°C)

    // --- Thermo data ---
    const V_AgCl = -109.8e3 / F; // ~ -1.1 V
    const V_std_Na_H = -261.91e3 / F; // ~ -2.7 V
    const V_std_Cl_H = -131.23e3 / -F; // ~ +1.3 V

    const diagram = new ElectrochemicalSpeciesBandDiagram(plotContainerId, {
        na_ion: SPECIES.sodium,
        cl_ion: SPECIES.chloride,
        electron: SPECIES.electron,
    });

    const boundaries = [0.0, 1.0];
    diagram.setSpatialLayout(boundaries, [REGION.solution]);
    diagram.setVRange(-4.8, +2.4);

    // --- Calculation Function ---
    function doUpdate() {
        const dphi = parseFloat(phiSlider.value);
        const log_c = parseFloat(concSlider.value);
        const c_NaCl = Math.pow(10, log_c);

        concValueSpan.textContent = c_NaCl.toExponential(2);

        const Vth = (R * T) / F;
        const c_Na = c_NaCl;
        const c_Cl = c_NaCl;

        const V_e = 0.0 + dphi;
        const V_Cl = V_e - V_AgCl;
        const V_Cl_std = V_Cl + Vth * Math.log(c_Cl);
        const V_Na_std = V_Cl_std + (V_std_Na_H - V_std_Cl_H);
        const V_Na = V_Na_std + Vth * Math.log(c_Na);

        const b = boundaries;
        diagram.updateTraceData([
            {
                id: `Cl_trace`,
                speciesId: 'cl_ion',
                curveType: 'voltage',
                showLabel: true,
                x: [b[0], b[1]],
                y: [V_Cl, V_Cl],
            },
            {
                id: `Cl_std_trace`,
                speciesId: 'cl_ion',
                curveType: 'standardState',
                showLabel: true,
                x: [b[0], b[1]],
                y: [V_Cl_std, V_Cl_std],
            },
            {
                id: `Na_trace`,
                speciesId: 'na_ion',
                curveType: 'voltage',
                showLabel: true,
                x: [b[0], b[1]],
                y: [V_Na, V_Na],
            },
            {
                id: `Na_std_trace`,
                speciesId: 'na_ion',
                curveType: 'standardState',
                showLabel: true,
                x: [b[0], b[1]],
                y: [V_Na_std, V_Na_std],
            },
        ]);
    }

    // --- Wire up (static markup; no layout shift) ---
    makeSlider('{{idprefix}}-concSlider', () => doUpdate(), { fire: false });
    makeSlider('{{idprefix}}-phiSlider', () => doUpdate(), { fire: false });
    doUpdate();
</script>
