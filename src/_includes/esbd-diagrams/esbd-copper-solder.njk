<figure class="demo-container" style="max-width: 300px">
    <div
        style="height: 150px; max-width:200px"
        id="esbd-copper-solder-container"
    ></div>
    {% figcaption %}
        Where two electronic materials (like two metals) come into contact, $V_{\mathrm{e}^-}$ equalizes as
        expected for an electronic circuit voltage, whereas $\phi$ settles on a
        nonzero step size&mdash;a so-called "built-in voltage". (Note: these $\phi$ values are made up; nobody knows the real values of $\phi$ that should be drawn here, only that they must differ.)
    {% endfigcaption %}
</figure>

<script type="module">
    import ElectrochemicalSpeciesBandDiagram from '{{ esbdJsPath }}ElectrochemicalSpeciesBandDiagram.js';
    import { SPECIES, REGION } from '{{ esbdJsPath }}figureDefs.js';

    const diagram = new ElectrochemicalSpeciesBandDiagram(
        'esbd-copper-solder-container',
        { electron: SPECIES.electron }
    );

    const boundaries = [0.0, 0.5, 1.0];
    diagram.setSpatialLayout(boundaries, [
        { name: 'Copper', color: '#F0B090' },
        { ...REGION.metal, name: 'Solder' },
    ]);

    const V_el = +0.45;
    diagram.setVRange(V_el - 0.3, V_el + 0.5);

    const b = boundaries;
    const data = [
        {
            id: `electron_trace`,
            speciesId: 'electron',
            curveType: 'voltage',
            showLabel: true,
            x: [0, 1],
            y: [V_el, V_el],
        },
    ];

    // phi steps by a (made-up) built-in voltage at the junction.
    const phis = [+0.4, -0.2];
    for (let i = 0; i < phis.length; i++) {
        const phi = V_el + phis[i];
        data.push({
            id: `phi_${i}`,
            curveType: 'phi',
            showLabel: true,
            x: [b[i], b[i + 1]],
            y: [phi, phi],
        });
    }

    diagram.updateTraceData(data);
</script>
