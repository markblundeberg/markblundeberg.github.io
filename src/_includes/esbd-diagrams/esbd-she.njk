{% set idprefix = "esbd-she" %} {# standard hydrogen electrode #}
{% import "macros/controls.njk" as controls %}
    <div class="bd-container" id="{{idprefix}}-container"></div>
    {{ controls.slider(idprefix + "-hplus-slider", "$\\mathrm{H}^+$ concentration", { min: -6.1, max: 1.1, step: "any", value: -1.7, readout: true, unit: "mol/kg", snap: 0 }) }}
    {{ controls.slider(idprefix + "-h2-slider", "$\\mathrm{H}_2$ pressure", { min: -2, max: 2, step: "any", value: -0.8, readout: true, unit: "bar", snap: 0 }) }}

<script type="module">
    import ElectrochemicalSpeciesBandDiagram from '{{ esbdJsPath }}ElectrochemicalSpeciesBandDiagram.js';
    import { SPECIES, REGION } from '{{ esbdJsPath }}figureDefs.js';
    import { makeSlider } from '{{ esbdJsPath }}utils.js';

    const hSlider = document.getElementById('{{ idprefix }}-hplus-slider');
    const hConcSpan = document.getElementById('{{ idprefix }}-hplus-slider-readout');
    const h2Slider = document.getElementById('{{ idprefix }}-h2-slider');
    const h2PressSpan = document.getElementById('{{ idprefix }}-h2-slider-readout');

    const diagram = new ElectrochemicalSpeciesBandDiagram('{{idprefix}}-container', {
        hplus: SPECIES.proton,
        electron: SPECIES.electron,
    });

    const boundaries = [0.0, 0.5, 1.0];
    diagram.setSpatialLayout(boundaries, [
        { ...REGION.metal, name: 'Inert metal' },
        REGION.solution,
    ]);

    const R = 8.31446261815324; // Gas constant (J/mol·K)
    const F = 96485.3321233100184; // Faraday constant (C/mol)
    const T = 298.15; // Temperature (K, 25°C)
    const RT = R * T;
    const RT_F = RT / F;

    diagram.setVRange(-0.17, 0.55);

    function updateDiagrams() {
        const a_hplus = Math.pow(10, parseFloat(hSlider.value));
        const a_h2 = Math.pow(10, parseFloat(h2Slider.value));

        hConcSpan.textContent = a_hplus.toExponential(2);
        h2PressSpan.textContent = a_h2.toPrecision(3);

        const mu_H2_1bar = 0; // chemical potential of H2 at 1 bar fugacity
        const mu_H2 = mu_H2_1bar + RT * Math.log(a_h2);

        const V_el = +0; // GND
        const V_H = V_el + mu_H2 / (2 * F);
        const V_H_std = V_H - RT_F * Math.log(a_hplus);

        const b = boundaries;
        diagram.updateTraceData([
            {
                id: `electron_trace`,
                speciesId: 'electron',
                curveType: 'voltage',
                showLabel: true,
                x: [b[0], b[1]],
                y: [V_el, V_el],
            },
            {
                id: `h_trace`,
                speciesId: 'hplus',
                curveType: 'voltage',
                showLabel: true,
                x: [b[1], b[2]],
                y: [V_H, V_H],
            },
            {
                id: `h_std_trace`,
                speciesId: 'hplus',
                curveType: 'standardState',
                showLabel: true,
                x: [b[1], b[2]],
                y: [V_H_std, V_H_std],
            },
        ]);

        diagram.updateVerticalMarkers([
            {
                id: 'x',
                symbol: '⇌',
                x: b[1],
                yDefs: [{ y: V_el }, { y: V_H }],
                popupCallback: () =>
                    String.raw`$\mathrm{H}^+ + \mathrm{e}^- \rightleftharpoons \tfrac{1}{2}\mathrm{H}_2$`,
            },
        ]);
    }

    makeSlider('{{idprefix}}-hplus-slider', () => updateDiagrams(), { fire: false });
    makeSlider('{{idprefix}}-h2-slider', () => updateDiagrams(), { fire: false });
    updateDiagrams();
</script>
