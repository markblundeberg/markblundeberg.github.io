{% set idprefix = "esbd-cc-donnan" %}
{% import "macros/controls.njk" as controls %}
<div class="bd-container" id="{{idprefix}}-container" style="height: 280px"></div>
{{ controls.slider(idprefix + "-pr-slider", "Trapped protein [Pr⁻]", { min: -4, max: 0, step: 0.1, value: -2, readout: true, unit: "mol/L" }) }}
<div style="text-align: center; font-size: 0.8em; color: #444; margin-top: 0.3em; line-height: 1.5">Right side: [Na⁺] <span id="{{idprefix}}-naConc"></span>&emsp;[Cl⁻] <span id="{{idprefix}}-clConc"></span> mol/L&emsp;·&emsp;Donnan step <span id="{{idprefix}}-step"></span> mV</div>

<script type="module">
    import ElectrochemicalSpeciesBandDiagram from '{{ esbdJsPath }}ElectrochemicalSpeciesBandDiagram.js';
    import { SPECIES, REGION } from '{{ esbdJsPath }}figureDefs.js';
    import { makeSlider, linspace } from '{{ esbdJsPath }}utils.js';

    // Exact Gibbs-Donnan equilibrium: 1:1 saline at c_s = 1 mM on both sides of
    // a membrane; an impermeant z=-1 protein at concentration P on the right.
    // Flat V_Na, V_Cl (both ions equilibrated) + mass action c_Na*c_Cl = c_s^2
    // + right-side neutrality c_Na = c_Cl + P give
    //   r = c_Na(right)/c_s = P/2c_s + sqrt(P^2/4c_s^2 + 1),
    //   Donnan step = -(RT/F) ln r  (ladder sits lower on the protein side).
    // NOTE: the drawn V°_Cl - V°_Na spacing is COMPRESSED to 1.2 V for display
    // (the real aqueous value is 4.0746 V); gaps and the step are to scale.
    const VT = 0.025693; // RT/F (V)
    const C_S = 1e-3;
    const LADDER = 1.2; // compressed rung spacing (see note)

    const naSpan = document.getElementById('{{idprefix}}-naConc');
    const clSpan = document.getElementById('{{idprefix}}-clConc');
    const stepSpan = document.getElementById('{{idprefix}}-step');
    const readout = document.getElementById('{{idprefix}}-pr-slider-readout');

    const diagram = new ElectrochemicalSpeciesBandDiagram(
        '{{idprefix}}-container',
        { sodium: SPECIES.sodium, chloride: SPECIES.chloride },
        { margins: { right: 62 } }
    );
    const boundaries = [0, 0.49, 0.51, 1];
    diagram.setSpatialLayout(boundaries, [
        { ...REGION.solution, name: 'Saline' },
        { name: '', color: '#c8c8c8' },
        { ...REGION.solution2, name: 'Saline + Pr⁻' },
    ]);
    diagram.setVRange(-0.12, 1.72);

    const x = linspace(0, 1, 101);
    const stepProfile = x.map((xi) => {
        const t = Math.min(1, Math.max(0, (xi - 0.47) / 0.06));
        return t * t * (3 - 2 * t);
    });

    function update(logP) {
        const P = Math.pow(10, logP);
        readout.textContent = P.toExponential(1);

        const r = P / (2 * C_S) + Math.sqrt((P * P) / (4 * C_S * C_S) + 1);
        const dDonnan = -VT * Math.log(r);
        naSpan.textContent = (C_S * r).toExponential(2);
        clSpan.textContent = (C_S / r).toExponential(2);
        stepSpan.textContent = (1000 * dDonnan).toFixed(0);

        const V_Na = 0; // gauge
        const V0Na_L = V_Na - VT * Math.log(C_S); // +0.178
        const V0Cl_L = V0Na_L + LADDER;
        const V_Cl = V0Cl_L - VT * Math.log(C_S); // z=-1: gap has opposite sign

        diagram.updateTraceData([
            {
                id: 'vcl',
                speciesId: 'chloride',
                curveType: 'voltage',
                x: [0, 1],
                y: [V_Cl, V_Cl],
            },
            {
                id: 'v0cl',
                speciesId: 'chloride',
                curveType: 'standardState',
                labelFrac: 0.1,
                x: x,
                y: stepProfile.map((t) => V0Cl_L + t * dDonnan),
            },
            {
                id: 'v0na',
                speciesId: 'sodium',
                curveType: 'standardState',
                labelFrac: 0.1,
                x: x,
                y: stepProfile.map((t) => V0Na_L + t * dDonnan),
            },
            {
                id: 'vna',
                speciesId: 'sodium',
                curveType: 'voltage',
                x: [0, 1],
                y: [V_Na, V_Na],
            },
        ]);
    }

    makeSlider('{{idprefix}}-pr-slider', update);
</script>
